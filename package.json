{
  "name": "@speranto/speranto",
  "version": "0.2.2",
  "license": "MIT",
  "author": "Imre Gelens",
  "homepage": "https://github.com/ImreC/speranto",
  "repository": {
    "type": "git",
    "url": "https://github.com/ImreC/speranto"
  },
  "description": "A quick and simple machine translation tool for i18n in webapps. Translate JSON, JS/TS, Markdown files and database content using OpenAI, Mistral, or Ollama.",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "module": "dist/index.mjs",
  "type": "module",
  "bin": {
    "speranto": "dist/index.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "scripts": {
    "types": "tsc src/types.ts --declaration --emitDeclarationOnly --outDir dist",
    "build": "tsdown",
    "link": "bun run build && bun link",
    "sync:version": "bun run scripts/version.ts sync",
    "bump:version": "bun run scripts/version.ts",
    "bump:patch": "bun run scripts/version.ts patch",
    "bump:minor": "bun run scripts/version.ts minor",
    "bump:major": "bun run scripts/version.ts major",
    "example:seed": "bun run scripts/seed-example-db.ts",
    "example": "bun run example:seed && cd example_content && bun ../index.ts",
    "docker:up": "docker compose -p speranto -f tests/docker-compose.yml up -d --wait",
    "test": "bun run docker:up && LLM_API_KEY=test bun test"
  },
  "devDependencies": {
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/bun": "latest",
    "@types/pg": "^8.11.10",
    "@types/sql.js": "^1.4.9",
    "@vitest/ui": "^3.2.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@babel/generator": "^7.28.0",
    "@babel/parser": "^7.28.0",
    "@babel/traverse": "^7.28.0",
    "@babel/types": "^7.28.2",
    "@types/glob": "^9.0.0",
    "@types/mdast": "^4.0.4",
    "commander": "^14.0.0",
    "glob": "^11.0.3",
    "listr2": "^9.0.1",
    "openai": "^5.11.0",
    "pg": "^8.13.1",
    "remark": "^15.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "sql.js": "^1.12.0",
    "tsdown": "^0.17.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  }
}
